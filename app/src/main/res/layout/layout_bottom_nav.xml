<?xml version="1.0" encoding="utf-8"?>
<!-- Instagram-style: flat, full-width, top-border divider only. Height = 64dp. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavBar"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="8dp"
    android:orientation="horizontal">

    <!-- Home tab -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconHome"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_nav_home"
            android:contentDescription="Home"
            app:tint="@color/on_surface_variant" />
    </LinearLayout>

    <!-- Search / Collections tab -->
    <LinearLayout
        android:id="@+id/navSearch"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconSearch"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_nav_collections"
            android:contentDescription="Collections"
            app:tint="@color/on_surface_variant" />
    </LinearLayout>

    <!-- Add / Create tab -->
    <LinearLayout
        android:id="@+id/navAdd"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_add"
            android:contentDescription="Create"
            app:tint="@color/on_surface" />
    </LinearLayout>

    <!-- Analytics / Results tab -->
    <LinearLayout
        android:id="@+id/navAnalytics"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconAnalytics"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_nav_reports"
            android:contentDescription="Reports"
            app:tint="@color/on_surface_variant" />
    </LinearLayout>

    <!-- Profile tab -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:orientation="vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iconProfile"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Profile"
            android:src="@drawable/ic_nav_profile"
            android:padding="1dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Circle"
            app:strokeWidth="2dp"
            app:strokeColor="@color/on_surface_variant"
            app:tint="@color/on_surface_variant" />
    </LinearLayout>

</LinearLayout>
