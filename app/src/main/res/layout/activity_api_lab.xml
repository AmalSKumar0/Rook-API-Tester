<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".ApiLabActivity">

    <include layout="@layout/layout_app_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to test? 🚀"
                android:textColor="@color/on_surface"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Configure your request details below."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <!-- Request Builder Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_soft_brutalist"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/layoutProjectSelection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Collection"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerProject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API Path"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApiPath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/dialog_brutalist_bg"
                    android:hint="/v1/users"
                    android:padding="16dp"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Endpoint URL"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApiUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/dialog_brutalist_bg"
                    android:hint="https://api.example.com/v1/users"
                    android:padding="16dp"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:inputType="textUri" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Description"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApiDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/dialog_brutalist_bg"
                    android:hint="User authentication endpoint"
                    android:padding="16dp"
                    android:textSize="13sp"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Method"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGet"
                            style="@style/Widget.Bubbly.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GET"
                            android:minWidth="80dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPost"
                            style="@style/Widget.Bubbly.Button.Secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="POST"
                            android:minWidth="80dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPut"
                            style="@style/Widget.Bubbly.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="PUT"
                            android:minWidth="80dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDelete"
                            style="@style/Widget.Bubbly.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="DELETE"
                            android:minWidth="80dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@android:color/transparent"
                    app:tabIndicatorColor="@color/primary"
                    app:tabSelectedTextColor="@color/primary"
                    app:tabTextColor="@color/on_surface_variant">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Headers" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Body" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auth" />
                </com.google.android.material.tabs.TabLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/etHeaders"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@drawable/dialog_brutalist_bg"
                        android:gravity="top"
                        android:hint="Content-Type: application/json\nAuthorization: Bearer token"
                        android:padding="12dp"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:inputType="textMultiLine"
                        android:visibility="visible" />

                    <EditText
                        android:id="@+id/etBody"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@drawable/dialog_brutalist_bg"
                        android:gravity="top"
                        android:hint="{\n  \&quot;key\&quot;: \&quot;value\&quot;\n}"
                        android:padding="12dp"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:inputType="textMultiLine"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutAuth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dialog_brutalist_bg"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auth Type"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinnerAuthType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" />

                        <EditText
                            android:id="@+id/etAuthToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/dialog_brutalist_bg"
                            android:hint="Token"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:inputType="text"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layoutBasicAuth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <EditText
                                android:id="@+id/etAuthUsername"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/dialog_brutalist_bg"
                                android:hint="Username"
                                android:padding="12dp"
                                android:textSize="13sp"
                                android:inputType="text" />

                            <EditText
                                android:id="@+id/etAuthPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/dialog_brutalist_bg"
                                android:hint="Password"
                                android:padding="12dp"
                                android:textSize="13sp"
                                android:inputType="textPassword" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvNoAuth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="No Authentication"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendRequest"
                        style="@style/Widget.Bubbly.Button"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="Send Request"
                        android:textSize="18sp"
                        app:icon="@drawable/ic_nav_add"
                        app:iconGravity="textEnd" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveApi"
                        style="@style/Widget.Bubbly.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:paddingHorizontal="24dp"
                        android:text="Save"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Response Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Response"
                        android:textColor="@color/on_surface"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/vStatusIndicator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_badge_neutral" />

                        <TextView
                            android:id="@+id/tvResponseStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="---"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="|"
                            android:textColor="@color/outline_variant" />

                        <TextView
                            android:id="@+id/tvResponseTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="0ms"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_soft_brutalist"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:background="@color/primary_container" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvResponseContent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Response will appear here after sending request."
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/divider_dotted" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvResponseSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Size: 0 KB"
                            android:textColor="@color/outline"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/btnCopyResponse"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:drawablePadding="4dp"
                            android:text="Copy JSON"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/ic_nav_collections" />
                    </RelativeLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/responseProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal" />
            </LinearLayout>

            <!-- Recent Activity Mini Bento -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_soft_brutalist"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/white"
                        android:padding="4dp"
                        android:src="@drawable/ic_nav_reports"
                        app:tint="@color/secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="History"
                        android:textColor="@color/on_secondary_fixed"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHistoryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24 requests today"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_soft_brutalist"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/white"
                        android:padding="4dp"
                        android:src="@drawable/ic_nav_collections"
                        app:tint="@color/tertiary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Favorites"
                        android:textColor="@color/on_tertiary_fixed"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFavoritesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 saved flows"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                </LinearLayout>
            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
